# Server port (default: 3001)
PORT=3001

# Host for noVNC URLs (default: localhost)
# Set to your server's hostname when deploying
VNC_HOST=localhost
# Bind noVNC host ports to loopback for security
VNC_BIND_IP=127.0.0.1
# Browser image used for per-session containers
CHROME_NOVNC_IMAGE=nkpro/chrome-novnc:latest
# Session container resources (Chrome is slow with 512MB)
CHROME_MEMORY_MB=768
CHROME_NANO_CPUS=2000000000
# Optional: wait until noVNC HTTP responds before returning session (API slower, UI opens cleaner)
# NOVNC_READY_WAIT=false
# NOVNC_READY_HOST=127.0.0.1
# On Docker Desktop API container use: host.docker.internal
# NOVNC_READY_TIMEOUT_MS=120000
# NOVNC_READY_POLL_MS=400

# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# JWT secret for OTP auth
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=1h
JWT_ISSUER=rebrowser-api
JWT_AUDIENCE=rebrowser-client

# OTP settings
OTP_TTL_MS=300000
MAX_OTP_ATTEMPTS=5
OTP_SEND_LIMIT_PER_MIN=3
OTP_VERIFY_LIMIT_PER_MIN=10
OTP_SEND_LIMIT_PER_MIN_EMAIL=3
OTP_VERIFY_LIMIT_PER_MIN_EMAIL=8
API_LIMIT_PER_MIN=30

# Persistent data dir (mount as volume in Docker)
DATA_DIR=/app/data

# Gmail SMTP credentials
APP_MAIL=your-email@gmail.com
APP_PASSWORD=your-app-password
